---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import YouTubeSection from '../components/YouTubeSection.astro';
import { projects, siteInfo, CATEGORY_META } from '../data/projects';

const featured = projects.filter((p) => p.featured);
const allProjects = projects;
---

<Layout>
  <!-- ═══ HERO ═══ -->
  <section id="home" class="relative min-h-screen flex items-center grid-line scanlines overflow-hidden">
    <!-- Background glow -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/3 left-1/4 w-96 h-96 bg-[#00f5ff]/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-[#bf00ff]/5 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 pt-28 pb-20 relative z-10">
      <!-- Status line -->
      <div class="flex items-center gap-2 text-xs font-mono text-[#00ff88] mb-6">
        <span class="w-2 h-2 bg-[#00ff88] rounded-full animate-pulse"></span>
        <span>SYSTEM ONLINE · Made in Thailand</span>
      </div>

      <!-- Name -->
      <h1 class="font-display font-black text-5xl sm:text-7xl md:text-8xl leading-none mb-4 relative">
        <span
          class="glitch text-white"
          data-text="ETLoLz"
          style="text-shadow: 0 0 40px rgba(0,245,255,0.3);"
        >
          ETLoLz
        </span>
      </h1>

      <!-- Role -->
      <div class="flex flex-wrap gap-3 mb-8 text-sm font-mono">
        {['Game Developer', 'AI Builder', 'Content Creator'].map((role) => (
          <span class="text-white/50">
            {role}
            <span class="text-[#00f5ff]/40 ml-3">·</span>
          </span>
        ))}
      </div>

      <!-- Tagline -->
      <p class="text-white/50 text-lg max-w-xl mb-10 leading-relaxed font-mono">
        Building <span class="text-[#00ff88]">games</span>,{' '}
        <span class="text-[#00f5ff]">AI systems</span>, and{' '}
        <span class="text-[#bf00ff]">content</span> out of Thailand.
      </p>

      <!-- CTA -->
      <div class="flex flex-wrap gap-4">
        <a href="#projects" class="btn-neon-cyan text-sm">
          ↓ ดูผลงาน
        </a>
        <a href="#contact" class="btn-neon text-sm border border-white/15 text-white/50 hover:text-white hover:border-white/40 transition-all">
          ติดต่อ
        </a>
      </div>

      <!-- Stats -->
      <div class="flex flex-wrap gap-8 mt-16 text-sm font-mono text-white/30">
        <div>
          <div class="text-2xl font-bold text-white/80">{projects.filter(p => p.category.startsWith('game')).length}</div>
          <div class="text-xs uppercase tracking-widest mt-1">Games</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-white/80">{projects.filter(p => p.category === 'ai').length}</div>
          <div class="text-xs uppercase tracking-widest mt-1">AI Projects</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-white/80">2026</div>
          <div class="text-xs uppercase tracking-widest mt-1">Active</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PROJECTS ═══ -->
  <section id="projects" class="py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <h2 class="section-title text-white">
        <span class="text-[#00f5ff]">//</span> Projects
      </h2>

      <!-- Category filter buttons -->
      <div class="flex flex-wrap gap-2 mb-8" id="filter-btns">
        <button data-filter="all" class="filter-btn active text-xs font-mono px-4 py-1.5 rounded border border-[#00f5ff]/50 text-[#00f5ff] bg-[#00f5ff]/10 transition-all">
          All ({allProjects.length})
        </button>
        {Object.entries(CATEGORY_META).map(([key, meta]) => {
          const count = allProjects.filter(p => p.category === key).length;
          if (count === 0) return null;
          return (
            <button
              data-filter={key}
              class="filter-btn text-xs font-mono px-4 py-1.5 rounded border border-white/15 text-white/40 hover:text-white hover:border-white/40 transition-all"
            >
              {meta.label} ({count})
            </button>
          );
        })}
      </div>

      <!-- Project grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4" id="project-grid">
        {allProjects.map((project) => (
          <div class="project-item" data-category={project.category}>
            <ProjectCard project={project} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ YOUTUBE ═══ -->
  <YouTubeSection />

  <!-- ═══ ABOUT ═══ -->
  <section id="about" class="py-20 px-6 border-t border-white/5">
    <div class="max-w-6xl mx-auto">
      <h2 class="section-title text-white">
        <span class="text-[#bf00ff]">//</span> About
      </h2>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <p class="text-white/60 leading-relaxed mb-6 font-mono text-sm">
            ผมเป็น Game Developer และ AI Builder จากประเทศไทย ชอบสร้างสิ่งที่ซับซ้อนให้ใช้งานได้จริง
            ตั้งแต่ RTS ที่มี horde 100k ตัว ยัน AI system ที่รันบนเครื่องตัวเองได้
          </p>
          <p class="text-white/40 leading-relaxed font-mono text-sm">
            ทำเนื้อหาใน YouTube ในชื่อ <span class="text-[#00f5ff]">ETLoLz</span> — AI Build, DevLog, และ Live session
          </p>
        </div>

        <div class="grid grid-cols-2 gap-3">
          {[
            { label: 'Game Dev', tools: ['Unity (DOTS)', 'Roblox Studio', 'Luau', 'C#'] },
            { label: 'AI / Dev', tools: ['Claude Code', 'MCP', 'Ollama', 'Python'] },
            { label: 'Platform', tools: ['Cloudflare Pages', 'GitHub', 'Steam', 'Roblox'] },
            { label: 'Tools', tools: ['Blender', 'Aseprite', 'VS Code', 'Git'] },
          ].map((group) => (
            <div class="card-cyber p-4 border border-white/8">
              <div class="text-xs font-mono text-[#00f5ff]/60 uppercase tracking-widest mb-3">{group.label}</div>
              <ul class="space-y-1">
                {group.tools.map((tool) => (
                  <li class="text-xs text-white/50 font-mono">— {tool}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CONTACT ═══ -->
  <section id="contact" class="py-20 px-6 border-t border-white/5">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="section-title text-white mb-4">
        <span class="text-[#00ff88]">//</span> Contact
      </h2>
      <p class="text-white/40 font-mono text-sm mb-12">ติดต่อได้ผ่านช่องทางด้านล่าง</p>

      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="mailto:oaketlolz@gmail.com"
          class="card-cyber px-6 py-4 border border-white/10 hover:border-[#00f5ff]/40 hover:text-[#00f5ff] transition-all group flex items-center gap-3"
        >
          <span class="text-xl">✉</span>
          <div class="text-left">
            <div class="text-xs text-white/30 font-mono uppercase tracking-wider mb-0.5">Email</div>
            <div class="text-sm font-mono text-white/70 group-hover:text-[#00f5ff]">oaketlolz@gmail.com</div>
          </div>
        </a>

        <a
          href="https://github.com/b2cm92ts5k-alt"
          target="_blank"
          rel="noopener"
          class="card-cyber px-6 py-4 border border-white/10 hover:border-[#00f5ff]/40 hover:text-[#00f5ff] transition-all group flex items-center gap-3"
        >
          <span class="text-xl">⌥</span>
          <div class="text-left">
            <div class="text-xs text-white/30 font-mono uppercase tracking-wider mb-0.5">GitHub</div>
            <div class="text-sm font-mono text-white/70 group-hover:text-[#00f5ff]">b2cm92ts5k-alt</div>
          </div>
        </a>

        <a
          href="https://www.youtube.com/channel/UCWRmazK-UdS6d0H2aQvXtsg"
          target="_blank"
          rel="noopener"
          class="card-cyber px-6 py-4 border border-white/10 hover:border-red-400/40 hover:text-red-400 transition-all group flex items-center gap-3"
        >
          <span class="text-xl">▶</span>
          <div class="text-left">
            <div class="text-xs text-white/30 font-mono uppercase tracking-wider mb-0.5">YouTube</div>
            <div class="text-sm font-mono text-white/70 group-hover:text-red-400">ETLoLz</div>
          </div>
        </a>

        <a
          href="https://www.roblox.com/communities/34023283"
          target="_blank"
          rel="noopener"
          class="card-cyber px-6 py-4 border border-white/10 hover:border-[#00ff88]/40 hover:text-[#00ff88] transition-all group flex items-center gap-3"
        >
          <span class="text-xl">⬡</span>
          <div class="text-left">
            <div class="text-xs text-white/30 font-mono uppercase tracking-wider mb-0.5">Roblox</div>
            <div class="text-sm font-mono text-white/70 group-hover:text-[#00ff88]">Forvex Labs</div>
          </div>
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Category filter
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const projectItems = document.querySelectorAll<HTMLElement>('.project-item');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'all';

      // Update active state
      filterBtns.forEach((b) => {
        b.classList.remove('active', 'text-[#00f5ff]', 'bg-[#00f5ff]/10', 'border-[#00f5ff]/50');
        b.classList.add('text-white/40', 'border-white/15');
      });
      btn.classList.add('active', 'text-[#00f5ff]', 'bg-[#00f5ff]/10', 'border-[#00f5ff]/50');
      btn.classList.remove('text-white/40', 'border-white/15');

      // Filter items
      projectItems.forEach((item) => {
        if (filter === 'all' || item.dataset.category === filter) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });
</script>
