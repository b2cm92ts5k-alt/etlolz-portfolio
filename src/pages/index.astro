---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import YouTubeSection from '../components/YouTubeSection.astro';
import { projects, siteInfo, CATEGORY_META } from '../data/projects';
import { models } from '../data/models';

const allProjects = projects;
---

<Layout>
  <!-- ═══ HERO ═══════════════════════════════════════════════════════════════ -->
  <section id="home" class="relative min-h-screen flex items-center grid-line scanlines overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/4 left-1/5 w-[500px] h-[500px] rounded-full blur-3xl" style="background:radial-gradient(circle, rgba(255,26,46,0.07) 0%, transparent 70%);"></div>
      <div class="absolute bottom-1/4 right-1/4 w-80 h-80 rounded-full blur-3xl" style="background:radial-gradient(circle, rgba(179,0,17,0.05) 0%, transparent 70%);"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 pt-28 pb-20 relative z-10">
      <div class="flex items-center gap-2 text-xs font-mono mb-6" style="color:#00e577;">
        <span class="w-2 h-2 rounded-full animate-pulse" style="background:#00e577;"></span>
        SYSTEM ONLINE · Made in Thailand
      </div>

      <h1 class="font-display font-black text-6xl sm:text-8xl md:text-9xl leading-none mb-5 select-none">
        <span class="glitch" data-text="ETLoLz" style="color:white; text-shadow:0 0 50px rgba(255,26,46,0.25);">
          ETLoLz
        </span>
      </h1>

      <div class="flex flex-wrap gap-0 mb-8 text-sm font-mono text-white/40">
        {['Game Developer', 'AI Builder', 'Content Creator'].map((r, i) => (
          <span>{r}{i < 2 && <span class="mx-3 text-[#ff1a2e]/30">·</span>}</span>
        ))}
      </div>

      <p class="text-white/45 text-lg max-w-xl mb-10 leading-relaxed font-mono">
        Building <span style="color:#00e577;">games</span>,{' '}
        <span style="color:#ff1a2e;">AI systems</span>, and{' '}
        <span style="color:#ff4455;">content</span> out of Thailand.
      </p>

      <div class="flex flex-wrap gap-4">
        <a href="#projects" class="btn-neon-red text-sm">↓ ดูผลงาน</a>
        <a href="#contact"
           class="btn-neon text-sm border border-white/12 text-white/40 rounded hover:text-white hover:border-white/35 transition-all">
          ติดต่อ
        </a>
      </div>

      <div class="flex flex-wrap gap-10 mt-16 font-mono">
        {[
          { n: allProjects.filter(p => p.category.startsWith('game')).length, l: 'Games' },
          { n: allProjects.filter(p => p.category === 'ai' || p.category === 'web').length, l: 'Dev Projects' },
          { n: '2026', l: 'Active' },
        ].map(({ n, l }) => (
          <div>
            <div class="text-3xl font-bold text-white/85" style="font-family:Orbitron,sans-serif;">{n}</div>
            <div class="text-xs uppercase tracking-widest text-white/25 mt-1">{l}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ PROJECTS ════════════════════════════════════════════════════════════ -->
  <section id="projects" class="py-20 px-6 border-t border-white/5">
    <div class="max-w-6xl mx-auto">
      <h2 class="section-title text-white">
        <span style="color:#ff1a2e;">//</span> Projects
      </h2>

      <!-- Filter -->
      <div class="flex flex-wrap gap-2 mb-8" id="filter-btns">
        <button data-filter="all"
                class="filter-btn text-xs font-mono px-4 py-1.5 rounded border transition-all"
                style="color:#ff1a2e; border-color:rgba(255,26,46,0.5); background:rgba(255,26,46,0.1);">
          All ({allProjects.length})
        </button>
        {Object.entries(CATEGORY_META).map(([key, meta]) => {
          const count = allProjects.filter(p => p.category === key).length;
          if (!count) return null;
          return (
            <button data-filter={key}
                    class="filter-btn text-xs font-mono px-4 py-1.5 rounded border border-white/12 text-white/35 transition-all hover:text-white/70 hover:border-white/30">
              {meta.label} ({count})
            </button>
          );
        })}
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4" id="project-grid">
        {allProjects.map((project) => (
          <div class="project-item" data-category={project.category}>
            <ProjectCard project={project} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ YOUTUBE ══════════════════════════════════════════════════════════════ -->
  <YouTubeSection />

  <!-- ═══ 3D MODELS ════════════════════════════════════════════════════════════ -->
  <section id="models" class="py-20 px-6 border-t border-white/5">
    <div class="max-w-6xl mx-auto">
      <h2 class="section-title text-white">
        <span style="color:#aa00ff;">//</span> 3D Models
      </h2>

      {models.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {models.map((model) => (
            <div class="card-cyber border border-[#aa00ff]/25 overflow-hidden group">
              <div class="video-thumb aspect-video bg-dark-700">
                {model.videoId ? (
                  <>
                    <img src={`https://img.youtube.com/vi/${model.videoId}/hqdefault.jpg`}
                         alt={model.title} class="w-full h-full object-cover opacity-80" loading="lazy" />
                    <div class="play-btn">
                      <div class="play-icon" style="background:rgba(170,0,255,0.85);">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="white"><path d="M4 2l10 6-10 6V2z"/></svg>
                      </div>
                    </div>
                  </>
                ) : (
                  <img src={`/images/models/${model.image}`} alt={model.title}
                       class="w-full h-full object-cover opacity-85 group-hover:opacity-95 transition-opacity" loading="lazy" />
                )}
              </div>
              <div class="p-4">
                <div class="flex items-center justify-between mb-2">
                  <h3 class="font-display font-bold text-sm text-white">{model.title}</h3>
                  {model.software && (
                    <span class="text-xs font-mono px-2 py-0.5 rounded border border-[#aa00ff]/30 text-[#aa00ff]/70">{model.software}</span>
                  )}
                </div>
                {model.description && <p class="text-xs text-white/40 mb-3">{model.description}</p>}
                <div class="flex flex-wrap gap-1.5">
                  {model.tags.map((tag) => <span class="tag">{tag}</span>)}
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="border border-dashed border-[#aa00ff]/20 rounded-lg p-12 text-center">
          <div class="text-4xl mb-4 opacity-20" style="color:#aa00ff;">◈</div>
          <p class="text-white/25 font-mono text-sm mb-2">ยังไม่มีผลงาน 3D</p>
          <p class="text-white/15 font-mono text-xs">
            เพิ่มได้ที่ <code class="text-[#aa00ff]/40">src/data/models.ts</code>
            · วางรูปใน <code class="text-[#aa00ff]/40">public/images/models/</code>
          </p>
        </div>
      )}
    </div>
  </section>

  <!-- ═══ ABOUT ════════════════════════════════════════════════════════════════ -->
  <section id="about" class="py-20 px-6 border-t border-white/5">
    <div class="max-w-6xl mx-auto">
      <h2 class="section-title text-white">
        <span style="color:#ff1a2e;">//</span> About
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <p class="text-white/55 leading-relaxed mb-5 font-mono text-sm">{siteInfo.about.bio}</p>
          <p class="text-white/35 leading-relaxed font-mono text-sm">
            ทำเนื้อหาใน YouTube ในชื่อ{' '}
            <a href={siteInfo.social.youtube} target="_blank" class="text-[#ff1a2e] hover:underline">ETLoLz</a>
            {' '}— AI Build, DevLog, และ Live session
          </p>
        </div>
        <div class="grid grid-cols-2 gap-3">
          {siteInfo.about.skills.map((group) => (
            <div class="card-cyber p-4 border border-white/6">
              <div class="text-xs font-mono text-[#ff1a2e]/50 uppercase tracking-widest mb-3">{group.label}</div>
              <ul class="space-y-1">
                {group.items.map((item) => <li class="text-xs text-white/45 font-mono">— {item}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CONTACT ══════════════════════════════════════════════════════════════ -->
  <section id="contact" class="py-20 px-6 border-t border-white/5">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="section-title text-white mb-3">
        <span style="color:#ff1a2e;">//</span> Contact
      </h2>
      <p class="text-white/30 font-mono text-sm mb-12">ติดต่อได้ผ่านช่องทางด้านล่าง</p>

      <div class="flex flex-wrap justify-center gap-4">
        {[
          { icon: '✉', label: 'Email',    val: siteInfo.social.email,   href: `mailto:${siteInfo.social.email}`,   hoverColor: '#ff1a2e' },
          { icon: '⌥', label: 'GitHub',   val: 'b2cm92ts5k-alt',         href: siteInfo.social.github,              hoverColor: '#ff1a2e' },
          { icon: '▶', label: 'YouTube',  val: 'ETLoLz',                  href: siteInfo.social.youtube,             hoverColor: '#ff4444' },
          { icon: '⬡', label: 'Roblox',   val: 'Forvex Labs',             href: siteInfo.social.roblox,              hoverColor: '#00e577' },
        ].map(({ icon, label, val, href, hoverColor }) => (
          <a href={href} target={href.startsWith('mailto') ? undefined : '_blank'} rel="noopener"
             class="card-cyber px-6 py-4 border border-white/8 flex items-center gap-3 transition-all group"
             onmouseover={`this.style.borderColor='${hoverColor}40'; this.querySelector('.val').style.color='${hoverColor}';`}
             onmouseout={`this.style.borderColor='rgba(255,255,255,0.08)'; this.querySelector('.val').style.color='rgba(255,255,255,0.6)';`}>
            <span class="text-xl text-white/30">{icon}</span>
            <div class="text-left">
              <div class="text-xs text-white/25 font-mono uppercase tracking-wider mb-0.5">{label}</div>
              <div class="val text-sm font-mono text-white/60 transition-colors">{val}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items      = document.querySelectorAll<HTMLElement>('.project-item');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const f = btn.dataset.filter ?? 'all';

      filterBtns.forEach((b) => {
        b.style.color = 'rgba(255,255,255,0.35)';
        b.style.borderColor = 'rgba(255,255,255,0.12)';
        b.style.background = 'transparent';
      });
      btn.style.color = '#ff1a2e';
      btn.style.borderColor = 'rgba(255,26,46,0.5)';
      btn.style.background = 'rgba(255,26,46,0.1)';

      items.forEach((item) => {
        item.style.display = (f === 'all' || item.dataset.category === f) ? '' : 'none';
      });
    });
  });
</script>
