---
import { siteInfo } from '../data/projects';

const playlists = [
  { label: 'AI Build', desc: 'สร้าง AI System ด้วย Claude + MCP' },
  { label: 'DevLog', desc: 'บันทึกการพัฒนาเกม Echo Obby + Firewall' },
  { label: 'ETLive', desc: 'Live Coding / Building sessions' },
];
---

<section id="youtube" class="py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-baseline gap-4 mb-3">
      <h2 class="section-title text-white mb-0">YouTube</h2>
      <span class="text-[#00f5ff] text-sm font-mono">{siteInfo.youtube.handle}</span>
    </div>
    <p class="text-white/40 font-mono text-sm mb-10">{siteInfo.youtube.description}</p>

    <!-- Channel series -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
      {playlists.map((pl) => (
        <div class="card-cyber p-4 border border-white/8">
          <div class="text-xs font-mono text-[#00f5ff]/70 uppercase tracking-widest mb-1">Series</div>
          <div class="font-display font-bold text-white text-sm mb-1">{pl.label}</div>
          <p class="text-white/40 text-xs font-mono">{pl.desc}</p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="flex justify-center">
      <a
        href={siteInfo.youtube.url}
        target="_blank"
        rel="noopener"
        class="btn-neon-cyan flex items-center gap-3 text-sm"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M23.5 6.2a3 3 0 00-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 00.5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 002.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 002.1-2.1c.5-1.9.5-5.8.5-5.8s0-3.9-.5-5.8zM9.75 15.5v-7l6.25 3.5-6.25 3.5z"/>
        </svg>
        ดูช่อง ETLoLz บน YouTube
      </a>
    </div>
  </div>
</section>
