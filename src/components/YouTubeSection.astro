---
import { siteInfo } from '../data/projects';

const { youtube } = siteInfo;
const hasVideos = youtube.videos.length > 0;

const series = [
  { label: 'AI Build',  desc: 'สร้าง AI System ด้วย Claude + MCP' },
  { label: 'DevLog',    desc: 'บันทึกการพัฒนาเกม Echo Obby + Firewall' },
  { label: 'ETLive',    desc: 'Live Coding / Building sessions' },
];
---

<section id="youtube" class="py-20 px-6 border-t border-white/5">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-baseline gap-4 mb-2">
      <h2 class="section-title mb-0" style="color:white;">
        <span style="color:#ff1a2e;">//</span> YouTube
      </h2>
      <a href={youtube.url} target="_blank" rel="noopener"
         class="text-[#ff1a2e]/70 hover:text-[#ff1a2e] text-sm font-mono transition-colors">
        {youtube.handle}
      </a>
    </div>
    <p class="text-white/35 font-mono text-sm mb-10">{youtube.description}</p>

    {hasVideos ? (
      <!-- Video thumbnail grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
        {youtube.videos.map((v) => (
          <a href={`https://www.youtube.com/watch?v=${v.id}`}
             target="_blank" rel="noopener"
             class="card-cyber border border-white/8 hover:border-[#ff1a2e]/30 group overflow-hidden block">
            <div class="video-thumb aspect-video bg-dark-700">
              <img
                src={`https://img.youtube.com/vi/${v.id}/hqdefault.jpg`}
                alt={v.title}
                class="w-full h-full object-cover opacity-80 group-hover:opacity-95"
                loading="lazy"
              />
              <div class="play-btn">
                <div class="play-icon">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="white">
                    <path d="M4 2l10 6-10 6V2z"/>
                  </svg>
                </div>
              </div>
            </div>
            <div class="p-3">
              <div class="text-xs font-mono text-[#ff1a2e]/60 uppercase tracking-wider mb-1">{v.series}</div>
              <p class="text-sm text-white/70 group-hover:text-white transition-colors line-clamp-2 leading-snug">
                {v.title}
              </p>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <!-- Series cards (placeholder เมื่อยังไม่มี video IDs) -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
        {series.map((s) => (
          <div class="card-cyber p-4 border border-white/8">
            <div class="text-xs font-mono text-[#ff1a2e]/60 uppercase tracking-widest mb-1.5">Series</div>
            <div class="font-display font-bold text-white text-sm mb-1">{s.label}</div>
            <p class="text-white/35 text-xs font-mono">{s.desc}</p>
          </div>
        ))}
      </div>
      <p class="text-white/20 text-xs font-mono text-center mb-8">
        ← เพิ่ม Video ID ใน <code class="text-[#ff1a2e]/50">src/data/projects.ts → siteInfo.youtube.videos</code> เพื่อแสดง thumbnail
      </p>
    )}

    <div class="flex justify-center">
      <a href={youtube.url} target="_blank" rel="noopener" class="btn-neon-red flex items-center gap-3 text-sm">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M23.5 6.2a3 3 0 00-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 00.5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 002.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 002.1-2.1c.5-1.9.5-5.8.5-5.8s0-3.9-.5-5.8zM9.75 15.5v-7l6.25 3.5-6.25 3.5z"/>
        </svg>
        ดูช่อง ETLoLz บน YouTube
      </a>
    </div>
  </div>
</section>
