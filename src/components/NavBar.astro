---
const navLinks = [
  { label: 'Home', href: '#home' },
  { label: 'Projects', href: '#projects' },
  { label: 'YouTube', href: '#youtube' },
  { label: 'About', href: '#about' },
  { label: 'Contact', href: '#contact' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
    <!-- Logo -->
    <a
      href="#home"
      class="font-display font-bold text-lg tracking-widest text-[#00f5ff] hover:text-white transition-colors"
      style="text-shadow: 0 0 10px #00f5ff80;"
    >
      ET<span class="text-white/60">LoLz</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-6 text-sm">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-white/50 hover:text-[#00f5ff] transition-colors duration-200 font-mono uppercase tracking-wider text-xs"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile menu button -->
    <button id="menu-btn" class="md:hidden text-white/50 hover:text-white p-1">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
        <rect y="3" width="20" height="2" rx="1"/>
        <rect y="9" width="20" height="2" rx="1"/>
        <rect y="15" width="20" height="2" rx="1"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 bg-dark-900/95 backdrop-blur-md">
    <ul class="flex flex-col px-6 py-4 gap-4">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-nav-link text-white/60 hover:text-[#00f5ff] transition-colors font-mono text-sm uppercase tracking-wider"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  #navbar.scrolled {
    background: rgba(5, 5, 15, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0, 245, 255, 0.08);
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  });

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  mobileLinks.forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });
</script>
