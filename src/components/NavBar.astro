---
const navLinks = [
  { label: 'Home',     href: '#home' },
  { label: 'Projects', href: '#projects' },
  { label: 'YouTube',  href: '#youtube' },
  { label: '3D',       href: '#models' },
  { label: 'About',    href: '#about' },
  { label: 'Contact',  href: '#contact' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
    <a href="#home" class="font-display font-bold text-lg tracking-widest hover:opacity-80 transition-opacity">
      <span style="color:#ff1a2e; text-shadow:0 0 12px #ff1a2e80;">ET</span><span class="text-white/70">LoLz</span>
    </a>

    <ul class="hidden md:flex items-center gap-6">
      {navLinks.map((link) => (
        <li>
          <a href={link.href}
             class="nav-link text-white/40 hover:text-white transition-colors duration-200 font-mono uppercase tracking-wider text-xs">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <button id="menu-btn" class="md:hidden text-white/50 hover:text-white p-1">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
        <rect y="3"  width="20" height="2" rx="1"/>
        <rect y="9"  width="20" height="2" rx="1"/>
        <rect y="15" width="20" height="2" rx="1"/>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 bg-dark-900/95 backdrop-blur-md">
    <ul class="flex flex-col px-6 py-4 gap-4">
      {navLinks.map((link) => (
        <li>
          <a href={link.href}
             class="mobile-link text-white/50 hover:text-[#ff1a2e] transition-colors font-mono text-sm uppercase tracking-wider">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  #navbar.scrolled {
    background: rgba(8, 5, 8, 0.93);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(255, 26, 46, 0.12);
  }
  .nav-link:hover { color: #ff1a2e !important; }
</style>

<script>
  const navbar    = document.getElementById('navbar')!;
  const menuBtn   = document.getElementById('menu-btn')!;
  const mobileMenu= document.getElementById('mobile-menu')!;

  window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 20);
  });

  menuBtn.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));
  document.querySelectorAll('.mobile-link').forEach(l =>
    l.addEventListener('click', () => mobileMenu.classList.add('hidden'))
  );
</script>
