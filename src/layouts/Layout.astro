---
import '../styles/global.css';
import NavBar from '../components/NavBar.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'ETLoLz — Game Dev · AI Builder · Creator',
  description = 'Portfolio of ETLoLz — Building games, AI systems, and content out of Thailand.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#05050f" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- OG -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body class="min-h-screen">
    <NavBar />
    <main>
      <slot />
    </main>
    <footer class="border-t border-white/5 py-8 mt-24">
      <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-white/30 font-mono">
        <span>© 2026 ETLoLz — Made in Thailand</span>
        <div class="flex gap-6">
          <a href="https://github.com/b2cm92ts5k-alt" target="_blank" class="hover:text-[#00f5ff] transition-colors">GitHub</a>
          <a href="https://www.youtube.com/channel/UCWRmazK-UdS6d0H2aQvXtsg" target="_blank" class="hover:text-[#00f5ff] transition-colors">YouTube</a>
        </div>
      </div>
    </footer>
  </body>
</html>
